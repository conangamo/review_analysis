# Environment variables example
# Copy this file to .env and fill in your values
# Usage: cp .env.example .env

# ============================================
# Database Configuration
# ============================================
DB_PATH=./data/processed/reviews.db
DB_TIMEOUT=30
DB_ECHO=false  # Set to true for SQL debugging

# ============================================
# Hugging Face Configuration
# ============================================
# Optional: Only needed for private models or to avoid rate limits
HF_TOKEN=
HF_CACHE_DIR=./data/cache/models

# ============================================
# GPU Settings
# ============================================
# Which GPU to use (0 for first GPU, -1 for CPU)
CUDA_VISIBLE_DEVICES=0
USE_GPU=true
USE_FP16=true  # Mixed precision for faster inference

# ============================================
# AI Model Configuration
# ============================================
MODEL_NAME=valhalla/distilbart-mnli-12-3
# Alternative models (uncomment to use):
# MODEL_NAME=facebook/bart-large-mnli
# MODEL_NAME=MoritzLaurer/deberta-v3-base-zeroshot-v1.1-all-33

# ============================================
# Processing Configuration
# ============================================
BATCH_SIZE=32
ANALYSIS_BATCH_SIZE=32
PARSE_BATCH_SIZE=1000
CHECKPOINT_INTERVAL=10  # Save checkpoint every N batches
CHECKPOINT_DIR=./data/cache/checkpoints
USE_KEYWORD_FILTER=true
CONFIDENCE_THRESHOLD=0.65
MIN_CONFIDENCE_TIER1=0.55
MIN_CONFIDENCE_TIER2=0.70

# ============================================
# Data Configuration
# ============================================
MIN_REVIEWS=20  # Minimum reviews per product
TOP_PRODUCTS=3000  # Number of products to sample
MIN_TEXT_LENGTH=20  # Minimum review text length (words)

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=./logs/app.log
LOG_TO_CONSOLE=true
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================
# Cache Configuration
# ============================================
CACHE_DIR=./data/cache
ENABLE_CACHE=true
CACHE_SIZE_MB=1024  # Maximum cache size in MB

# ============================================
# Streamlit UI Configuration
# ============================================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost
STREAMLIT_THEME=light  # light or dark

# ============================================
# Data Download Configuration
# ============================================
AMAZON_DATA_BASE_URL=https://mcauleylab.ucsd.edu/public_datasets/data/amazon_2023/raw
DOWNLOAD_TIMEOUT=3600  # 1 hour timeout for large files

# ============================================
# Development Settings
# ============================================
# Set to true to use sample data for faster testing
USE_SAMPLE_DATA=false
SAMPLE_SIZE=1000  # Number of reviews to use in sample mode

# Set to true to skip expensive operations during development
SKIP_AI_ANALYSIS=false
SKIP_SUMMARY_GENERATION=false
